    "    \"\\n\",\n",
    "    \"# Format columns\\n\",\n",
    "    \"paper_table['mean_before'] = paper_table['mean_before'].round(3)\\n\",\n",
    "    \"paper_table['mean_after'] = paper_table['mean_after'].round(3)\\n\",\n",
    "    \"paper_table['mean_diff'] = paper_table['mean_diff'].round(3)\\n\",\n",
    "    \"paper_table['t_statistic'] = paper_table['t_statistic'].round(3)\\n\",\n",
    "    \"paper_table['effect_size_cohens_d'] = paper_table['effect_size_cohens_d'].round(3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Format p-values with stars\\n\",\n",
    "    \"def format_pvalue(p):\\n\",\n",
    "    \"    if p < 0.001:\\n\",\n",
    "    \"        return f\\\"{p:.4f}***\\\"\\n\",\n",
    "    \"    elif p < 0.01:\\n\",\n",
    "    \"        return f\\\"{p:.4f}**\\\"\\n\",\n",
    "    \"    elif p < 0.05:\\n\",\n",
    "    \"        return f\\\"{p:.4f}*\\\"\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        return f\\\"{p:.4f}\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"paper_table['t_pvalue_fmt'] = paper_table['t_pvalue'].apply(format_pvalue)\\n\",\n",
    "    \"paper_table['wilcoxon_pvalue_fmt'] = paper_table['wilcoxon_pvalue'].apply(format_pvalue)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Rename columns for clarity\\n\",\n",
    "    \"paper_table = paper_table.rename(columns={\\n\",\n",
    "    \"    'model': 'Model',\\n\",\n",
    "    \"    'dimension': 'Dimension',\\n\",\n",
    "    \"    'n_pairs': 'N',\\n\",\n",
    "    \"    'mean_before': 'M_before',\\n\",\n",
    "    \"    'mean_after': 'M_after',\\n\",\n",
    "    \"    'mean_diff': 'Δ',\\n\",\n",
    "    \"    't_statistic': 't',\\n\",\n",
    "    \"    't_pvalue_fmt': 'p (t-test)',\\n\",\n",
