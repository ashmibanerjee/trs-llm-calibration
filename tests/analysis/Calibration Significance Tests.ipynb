    "    \"print(\\\"=\\\"*120)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Save as CSV and LaTeX\\n\",\n",
    "    \"output_dir = Path(\\\"../../data/artifacts/llm-eval\\\")\\n\",\n",
    "    \"final_table.to_csv(output_dir / 'calibration_sig_tests_formatted.csv', index=False)\\n\",\n",
    "    \"final_table.to_latex(output_dir / 'calibration_sig_tests_table.tex', index=False)\\n\",\n",
    "    \"\\n\",\n",
