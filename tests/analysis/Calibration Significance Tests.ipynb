    "    \"print(f\\\"   - {output_dir / 'calibration_sig_tests_formatted.csv'}\\\")\\n\",\n",
    "    \"print(f\\\"   - {output_dir / 'calibration_sig_tests_table.tex'}\\\")\"\n",
    "   ]\n",
