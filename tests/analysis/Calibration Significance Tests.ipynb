    "    \"    'effect_size_cohens_d': \\\"Cohen's d\\\"\\n\",\n",
    "    \"})\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Select and reorder columns\\n\",\n",
    "    \"final_table = paper_table[['Model', 'Dimension', 'N', 'M_before', 'M_after', 'Δ', \\n\",\n",
    "    \"                           't', 'p (t-test)', 'p (Wilcoxon)', \\\"Cohen's d\\\"]]\\n\",\n",
    "    \"\\n\",\n",
